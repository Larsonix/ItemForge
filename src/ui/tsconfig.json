{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["lib/types/vuetale-core/*"]
    }
  },
  "include": [
    "lib/**/*.ts",
    "lib/**/*.vue",
    "env.d.ts"
  ]
}
